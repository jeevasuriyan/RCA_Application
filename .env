PORT=4300
MONGO_URI=mongodb://127.0.0.1:27017
DB_NAME=rca_app

# ── JWT ───────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=rca_app_jwt_secret_CHANGE_ME_IN_PRODUCTION_2024
JWT_EXPIRES=24h

# ── Default user (created automatically on first server start) ──
DEFAULT_USER_EMAIL=admin@rcaapp.com
DEFAULT_USER_PASSWORD=Admin@12345
DEFAULT_USER_NAME=Admin
